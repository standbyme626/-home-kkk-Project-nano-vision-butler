{
  "agents": {
    "defaults": {
      "workspace": "./gateway/nanobot_workspace/dev",
      "model": "__SET_QWEN_MODEL_NAME_DEV__",
      "provider": "openai"
    }
  },
  "channels": {
    "sendProgress": true,
    "sendToolHints": true,
    "telegram": {
      "enabled": true,
      "token": "__SET_TELEGRAM_BOT_TOKEN_DEV__",
      "allowFrom": [
        "__SET_TELEGRAM_USER_ID_DEV__"
      ],
      "replyToMessage": true
    }
  },
  "providers": {
    "openai": {
      "apiBase": "__SET_QWEN_API_BASE_DEV__",
      "apiKey": "__SET_QWEN_API_KEY_DEV__"
    }
  },
  "gateway": {
    "host": "0.0.0.0",
    "port": 18791
  },
  "tools": {
    "restrictToWorkspace": false,
    "defaultToolTimeoutSec": 45,
    "maxConcurrentTools": 2,
    "mcpServers": {
      "vision-butler-mcp-dev": {
        "url": "http://100.92.134.46:8001/mcp",
        "toolTimeout": 45
      }
    }
  }
}
